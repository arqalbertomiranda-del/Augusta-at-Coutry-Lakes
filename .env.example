# Augusta at Country Lakes — Variables de entorno
# Copia este archivo a .env y rellena los valores reales
# NUNCA commitees el archivo .env con valores reales

# ── Arcads (generación de imágenes y video con influencers) ──────────────────
ARCADS_AUTH=Basic <tu_token_base64_aqui>
ARCADS_PRODUCT_ID=<product_id>
ARCADS_PROJECT_ID=<project_id>

# ── ElevenLabs (voiceover de Isabela y Camila) ───────────────────────────────
ELEVENLABS_API_KEY=sk_<api_key_isabela>
# Voice ID Isabela (Jessica): cgSgspJ2msm6clMCkdW9
ELEVENLABS_API_KEY_CAMILA=sk_<api_key_camila>
# Voice ID Camila (Ana María): m7yTemJqdIqrcNleANfX

# ── fal.ai (Seedance 2.0 Pro — opcional, fallback a Arcads veo31) ────────────
FAL_KEY=<tu_fal_api_key_aqui>

# ── Odoo ERP (inventario de lotes en tiempo real) ────────────────────────────
ODOO_API_URL=https://<tu-instancia>.odoo.com
ODOO_API_KEY=<tu_odoo_api_key>
ODOO_DATABASE=<nombre_de_base_de_datos>

# ── HubSpot CRM (leads, pipeline, email sequences) ───────────────────────────
HUBSPOT_API_KEY=<tu_hubspot_private_app_token>
HUBSPOT_PORTAL_ID=<portal_id>

# ── WhatsApp Business API (notificaciones al equipo de ventas) ───────────────
WHATSAPP_API_TOKEN=<tu_whatsapp_business_api_token>
WHATSAPP_PHONE_ID=<phone_number_id>
WHATSAPP_SALES_NUMBER=<numero_asesor_con_codigo_pais>

# ── Buffer (scheduling de redes sociales) ────────────────────────────────────
BUFFER_ACCESS_TOKEN=<tu_buffer_access_token>

# ── Google / SEO ─────────────────────────────────────────────────────────────
GOOGLE_ANALYTICS_ID=G-<medicion_id>
GOOGLE_SEARCH_CONSOLE_SITE=https://augustacountrylakes.mx
